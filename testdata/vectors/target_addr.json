{
  "protocol": "nowhere-v1",
  "source": {
    "rust": "Nowhere/src/tests/protocol/util.rs::validates_host_port_forms"
  },
  "accept": [
    {
      "id": "target.empty-host.ok",
      "target": ":443"
    },
    {
      "id": "target.host.ok",
      "target": "example.com:443"
    },
    {
      "id": "target.ipv4.ok",
      "target": "93.184.216.34:443"
    },
    {
      "id": "target.ipv6.loopback.ok",
      "target": "[::1]:53"
    },
    {
      "id": "target.ipv6.ok",
      "target": "[2001:db8::1]:443"
    }
  ],
  "reject": [
    {
      "id": "target.empty",
      "target": "",
      "reason": "missing host and port separator"
    },
    {
      "id": "target.empty-port",
      "target": "example.com:",
      "reason": "empty port"
    },
    {
      "id": "target.ipv6.bad",
      "target": "2001:db8::1:443",
      "reason": "unbracketed IPv6 literal"
    },
    {
      "id": "target.ipv6.missing-bracket",
      "target": "[2001:db8::1",
      "reason": "missing closing bracket"
    },
    {
      "id": "target.ipv6.missing-colon-before-port",
      "target": "[2001:db8::1]443",
      "reason": "missing colon before port"
    },
    {
      "id": "target.no-port",
      "target": "no-port",
      "reason": "missing port separator"
    }
  ]
}
